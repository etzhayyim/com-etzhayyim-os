{
  "@context": "https://etzhayyim.com/ns/actor/v1",
  "@id": "did:web:os.etzhayyim.com",
  "capabilities": [
    "graph.query",
    "graph.write",
    "agent.chat",
    "agent.invoke",
    "derive:social"
  ],
  "complianceDocs": [
    "90-docs/rules/compliance/per-did-kyumei-shinka-autonomy.md",
    "90-docs/platform/260403-live-data-kyumei-shinka-consolidated.md"
  ],
  "convoSystemPrompt": "You are the Etzhayyim OS agent — the platform service layer for agent lifecycle management. You manage agent spawning and termination, consent request/grant flows, the DID directory, budget allocation per actor, audit log entries, and sync coordination. Query the graph for OsAgent, OsConsentRequest, OsBudgetAllocation, OsDirectoryEntry, and OsAuditEntry nodes. The KAMI compositor layer (Rust WASM window-manager) is handled separately; you manage only the service orchestration layer.",
  "description": "Agent lifecycle management, consent orchestration, directory resolution, budget allocation, audit trail, sync coordination, and window-manager service. The KAMI compositor (Rust WASM) remains T3; only the service layer migrates to T1 MCP-Compose.",
  "displayName": "Etzhayyim OS — Kotodama Service Layer",
  "domainKnowledgeRequired": true,
  "runtime": "k8s-langserver",
  "edge": "sveltekit-proxy",
  "legacyExecutionTier": "T1",
  "governance": {
    "classification": "internal",
    "raci": "responsible"
  },
  "heartbeatRequired": true,
  "name": "os",
  "nanoid": "os-etzhayyim-01",
  "performerType": "service",
  "pipelines": [
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (a:OsAgent) WHERE a.did = $input.record.requesterDid RETURN a.did AS agentDid, a.displayName AS name, a.status AS status, a.trustScore AS trustScore LIMIT 1"
          },
          "fn": "graph.query",
          "id": "requester"
        },
        {
          "args": {
            "message": "Consent request received: $input.record\n\nRequester agent: $requester.rows\n\nEvaluate whether this consent request should be auto-approved, queued for human review, or denied based on the requester trust score and requested scope. Return JSON: {decision: auto-approve|review|deny, reason}"
          },
          "fn": "agent.chat",
          "id": "evaluate"
        },
        {
          "args": {
            "template": "MERGE (c:OsConsentRequest {did: $did}) SET c.requesterDid = $input.record.requesterDid, c.scope = $input.record.scope, c.decision = $evaluate.text, c.repo = $did, c.collection = 'com.etzhayyim.apps.os.consentRequest'"
          },
          "fn": "graph.write",
          "id": "writeDecision"
        },
        {
          "args": {
            "template": "New data added: $evaluate.text"
          },
          "depends_on": [
            "evaluate"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "collections": [
          "com.etzhayyim.apps.os.consentRequest"
        ],
        "type": "subscribeRepos"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (a:OsAgent) WHERE a.did = $input.record.agentDid RETURN a.did AS agentDid, a.status AS status LIMIT 1"
          },
          "fn": "graph.query",
          "id": "existing"
        },
        {
          "args": {
            "message": "Agent lifecycle event: $input.record\n\nExisting agent state: $existing.rows\n\nProcess this lifecycle event (spawn/suspend/terminate/upgrade). Validate preconditions and return JSON: {action, agentDid, newStatus, budgetImpact}"
          },
          "fn": "agent.chat",
          "id": "lifecycle"
        },
        {
          "args": {
            "template": "MERGE (a:OsAgent {did: $input.record.agentDid}) SET a.displayName = $input.record.displayName, a.status = $input.record.action, a.tier = $input.record.tier, a.repo = $did, a.collection = 'com.etzhayyim.apps.os.agent'"
          },
          "depends_on": [
            "lifecycle"
          ],
          "fn": "graph.write",
          "id": "writeAgent"
        },
        {
          "args": {
            "template": "CREATE (e:OsAuditEntry {did: $did, action: $input.record.action, agentDid: $input.record.agentDid, detail: $lifecycle.text, repo: $did, collection: 'com.etzhayyim.apps.os.auditEntry'})"
          },
          "depends_on": [
            "lifecycle"
          ],
          "fn": "graph.write",
          "id": "audit"
        },
        {
          "args": {
            "template": "New data added: $lifecycle.text"
          },
          "depends_on": [
            "lifecycle"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "collections": [
          "com.etzhayyim.apps.os.agent"
        ],
        "type": "subscribeRepos"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (a:OsAgent) RETURN a.status AS status, count(a) AS total LIMIT 10"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "agentStats"
        },
        {
          "args": {
            "sql": "MATCH (b:OsBudgetAllocation) WHERE b.period = 'current' RETURN sum(b.allocated) AS totalAllocated, sum(b.consumed) AS totalConsumed, count(b) AS agentCount LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "budgetStats"
        },
        {
          "args": {
            "message": "Etzhayyim OS health check.\n\nAgent status distribution:\n$agentStats.rows\n\nBudget utilization:\n$budgetStats.rows\n\nSummarize platform health and flag any agents exceeding budget or in error state."
          },
          "depends_on": [
            "agentStats",
            "budgetStats"
          ],
          "fn": "agent.chat",
          "id": "summary"
        },
        {
          "args": {
            "template": "Etzhayyim OS status: $summary.text"
          },
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did RETURN count(n) AS nodeCount, coalesce(max(n._seq), 0) AS latestSeq LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageNodes"
        },
        {
          "args": {
            "sql": "MATCH (n) WHERE n.repo = $did AND n.collection IS NOT NULL RETURN n.collection AS collection, count(n) AS cnt ORDER BY cnt DESC LIMIT 10"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageCollections"
        },
        {
          "args": {
            "params": {
              "actorName": "os",
              "bucket": "6h",
              "collection": "com.etzhayyim.apps.os.coverageSnapshot",
              "latestSeq": 0,
              "nanoid": "os-etzhayyim-01",
              "nodeCount": "$coverageNodes.rows[0].nodeCount"
            },
            "template": "MERGE (c:ActorCoverageSnapshot {actorDid: $did, bucket: $bucket, actorName: $actorName, nanoid: $nanoid, nodeCount: $nodeCount, latestTs: $latestTs, repo: $did, collection: $collection, status: 'active'})"
          },
          "depends_on": [
            "coverageNodes",
            "coverageCollections"
          ],
          "fn": "graph.write",
          "id": "coverageSnapshot"
        },
        {
          "args": {
            "message": "You are Etzhayyim OS — Kotodama Service Layer. Based on the following new data, write a concise social post (1-2 sentences, informative and specific). Data: $coverageSnapshot.text"
          },
          "depends_on": [
            "coverageSnapshot"
          ],
          "fn": "agent.chat",
          "id": "compose"
        },
        {
          "args": {
            "template": "$compose.text"
          },
          "depends_on": [
            "compose"
          ],
          "fn": "derive:social",
          "id": "announce"
        }
      ],
      "trigger": {
        "cron": "0 */6 * * *",
        "type": "cron"
      }
    },
    {
      "steps": [
        {
          "args": {
            "sql": "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS nodeCount, c.latestSeq AS latestSeq, c.topCollections AS topCollections, c._seq AS snapshotSeq LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageStats"
        },
        {
          "args": {
            "sql": "MATCH (c:ActorCoverageSnapshot {actorDid: $did}) RETURN c.nodeCount AS totalNodes LIMIT 1"
          },
          "depends_on": [],
          "fn": "graph.query",
          "id": "coverageHealth"
        }
      ],
      "trigger": {
        "nsid": "com.etzhayyim.apps.os.coverage.get",
        "type": "xrpc"
      }
    }
  ],
  "profile": {
    "agentType": "autonomous",
    "capabilities": [
      "agent-lifecycle",
      "consent-orchestration",
      "directory-resolve",
      "budget-allocate",
      "audit-trail",
      "sync-coordinate"
    ],
    "description": "OS-level agent lifecycle, consent, directory, budget, audit, and sync services. Coordinates Kotodama actor spawning, permission grants, and resource allocation across the platform.",
    "displayName": "Etzhayyim OS — Kotodama Service Layer",
    "isBot": true,
    "operator": "etzhayyim.co.jp"
  },
  "requiredCollections": [
    "com.etzhayyim.apps.standard.shinkaEvolution",
    "com.etzhayyim.apps.standard.shinkaKnowledge"
  ],
  "requiredLoops": [
    "shinka",
    "koji",
    "kyumei",
    "domain-knowledge"
  ],
  "standardRule": "per-did-kyumei-shinka-autonomy@2026-04-13",
  "standardStatus": "required",
  "triggers": {
    "subscribeRepos": {
      "collections": [
        "com.etzhayyim.apps.os.agent",
        "com.etzhayyim.apps.os.consentRequest",
        "com.etzhayyim.apps.os.budgetAllocation",
        "com.etzhayyim.apps.os.directoryEntry"
      ]
    }
  },
  "uiType": "yoro"
}
